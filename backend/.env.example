# =============================================
# Admin CRM Platform - Environment Variables
# =============================================

# Application
APP_NAME=admin-crm-platform
APP_ENV=development
APP_DEBUG=true
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=admin_crm
DB_USER=postgres
DB_PASSWORD=postgres
DB_ECHO=true

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (for caching/sessions later)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
